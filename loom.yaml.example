# LOOM Configuration
# ===================
# 複製本文件為 loom.yaml 並根據你的環境修改。
# 敏感信息（API Key、Token）請寫入 .env，不要寫在這裡。
#
# 搜索順序：
#   1. $LOOM_CONFIG_FILE 環境變量指定的路徑
#   2. 當前工作目錄下的 loom.yaml
#   3. ~/.loom/loom.yaml
#   4. /etc/loom/loom.yaml
#
# 所有值均可被環境變量覆蓋，見各字段註釋中的環境變量名。

# ── 基礎路徑 ────────────────────────────────────
# 所有 LOOM 數據的根目錄（env: LOOM_DATA_DIR）
# data_dir: ~/.loom/data

# ── Finder ──────────────────────────────────────
finder:
  # 快速路由觸發閾值：在線模型數低於此值時跳過 embedding（env: LOOM_FAST_ROUTE_MAX_WORKERS）
  fast_route_max_workers: 3
  # 三維聚合權重（env: LOOM_FINDER_W_CAP / W_CTX / W_STA）
  w_cap: 0.5
  w_ctx: 0.3
  w_sta: 0.2
  # 語境緩衝區大小（env: LOOM_CONTEXT_BUFFER_SIZE）
  context_buffer_size: 500
  # 每條成功歷史的增量（env: LOOM_CONTEXT_BOOST）
  context_boost: 0.15
  # 模型池向量文件路徑（env: LOOM_VECTORS_PATH）
  # vectors_path: ~/.loom/worker_vectors.pkl
  # 模型註冊表文件路徑（env: LOOM_ROSTER_PATH）
  # roster_path: ~/.loom/roster.yaml
  # 語境緩衝區目錄（env: LOOM_CONTEXT_DIR）
  # context_dir: ~/.loom/finder_context

# ── 嵌入模型 ────────────────────────────────────
embedding:
  model: "BAAI/bge-small-en-v1.5"  # env: LOOM_EMBEDDING_MODEL
  dim: 384                          # env: LOOM_EMBEDDING_DIM

# ── Chroma ──────────────────────────────────────
chroma:
  collection: "loom_knowledge"     # env: LOOM_CHROMA_COLLECTION

# ── 分塊 ────────────────────────────────────────
chunker:
  max_chars: 500                    # env: LOOM_CHUNK_MAX_CHARS
  overlap: 50                       # env: LOOM_CHUNK_OVERLAP

# ── 檢索 ────────────────────────────────────────
retrieval:
  top_k: 5                          # env: LOOM_TOP_K_DEFAULT

# ── 飛輪事件 ────────────────────────────────────
flywheel:
  e1_thresholds: "10,50,100,200,500,1000"  # env: LOOM_E1_THRESHOLDS
  e2_drift_min: 0.05                       # env: LOOM_E2_DRIFT_MIN
  e3_min_entries: 200                      # env: LOOM_E3_MIN_ENTRIES
  e3_repack_growth: 30.0                   # env: LOOM_E3_REPACK_GROWTH
  e4_dedup_threshold: 0.95                 # env: LOOM_E4_DEDUP_THRESHOLD
  e5_stale_days: 90                        # env: LOOM_E5_STALE_DAYS

# ── 分類 ────────────────────────────────────────
classify:
  # seed_patterns_path: ~/.loom/seed_patterns.yaml

# ── 服務 ────────────────────────────────────────
server:
  host: "0.0.0.0"                   # env: LOOM_HOST
  port: 8765                        # env: LOOM_PORT

# ── 雲端模型池（內置默認值，供無 config.yaml 時兜底）────
# cloud_models:
#   - name: deepseek-v4-flash
#     provider: deepseek
#     is_free: false
#     cost: 0.00015
#     tags: [reasoning, coding]

# ── 探活端點 ────────────────────────────────────
# llama_server:
#   base_url: http://localhost:8000   # 可被 LOOM_LLAMA_BASE_URL env 覆寫

# health_endpoints:
#   local: http://localhost:8000/health
#   deepseek: https://api.deepseek.com/v1
#   openrouter: https://openrouter.ai/api/v1/models
