"""
KAFED FastAPI 入口 — RAG 服务。

端点:
    POST   /ingest         上传 Markdown/TXT → 分块 → 嵌入 → 存储
    POST   /ingest/convert 上传任意文档 → (调用外部 doc2md) → 分块 → 嵌入 → 存储
    GET    /query          语义搜索
    POST   /feedback       记录评分
    GET    /domains        列出所有域名
    GET    /stats          统计信息
    POST   /centroids      手动触发 centroid 重建
"""
from __future__ import annotations

import logging
import subprocess
import tempfile
from pathlib import Path
from typing import Optional

from fastapi import FastAPI, File, Form, HTTPException, Query, UploadFile
from pydantic import BaseModel

from .chunker import chunk_document
from .config import get_config
from .embedding import get_model
from .event_checker import EventChecker
from .rag_engine import RAGEngine
from .vector_store import VectorStore
from kafed import __version__

# ── 全局初始化（FastAPI startup 时） ────────────────────
_vs: VectorStore | None = None
_rag: RAGEngine | None = None
_checker: EventChecker | None = None
_cfg = get_config()


app = FastAPI(
    title="KAFED — Knowledge Agent Framework for Embedded Data",
    version=__version__,
    description="轻量 RAG 服务 + 事件驱动知识飞轮。接受 Markdown/TXT 格式的知识文本。",
)


@app.on_event("startup")
async def startup():
    global _vs, _rag, _checker
    get_model()
    _vs = VectorStore()
    _rag = RAGEngine(_vs)
    _checker = EventChecker(_vs, _rag)
    init_ok = _checker.status()
    logger = logging.getLogger("kafed")
    logger.info("KAFED startup: flywheel v%s, packed=%s",
                init_ok.get("version"), init_ok.get("packed_domains"))


@app.on_event("shutdown")
async def shutdown():
    pass


# ── Pydantic 模型 ──────────────────────────────────────

class QueryResponse(BaseModel):
    query_id: str
    question: str
    results: list[dict]
    total_found: int
    domain_context: dict | None = None


class FeedbackRequest(BaseModel):
    query_id: str
    doc_id: str
    score: int = 5  # 1-5
    user_id: str = "anonymous"


class IngestResponse(BaseModel):
    status: str
    chunks: int
    domain: str
    events: list[dict] = []
    convert_used: bool = False


class StatsResponse(BaseModel):
    total_chunks: int
    domains: list[dict]
    total_feedback: int
    centroids_count: int


# ── 支持的文件格式 ──────────────────────────────────────

TEXT_EXTENSIONS = {".md", ".markdown", ".txt"}


def _is_text_file(filename: str | None) -> bool:
    """判断文件是否为直接支持的文本格式。"""
    if not filename:
        return False
    return Path(filename).suffix.lower() in TEXT_EXTENSIONS


# ── 核心入口：/ingest（只接受 MD/TXT） ─────────────────

@app.post("/ingest", response_model=IngestResponse)
async def ingest_document(
    file: UploadFile = File(...),
    domain: str = Form("GENERAL"),
):
    """上传 Markdown 或 TXT 文件 → 分块 → 嵌入 → 存入 Chroma。

    PDF 等非文本格式请先通过 doc2md 转换，或使用 POST /ingest/convert。
    """
    if _vs is None or _rag is None or _checker is None:
        raise HTTPException(500, "服务未就绪")

    # 格式检查
    if not _is_text_file(file.filename):
        suffix = Path(file.filename or "unknown").suffix
        raise HTTPException(
            400,
            f"KAFED 核心 API 只接受 Markdown/TXT 文件（收到 {suffix}）。\n"
            f"请先用 doc2md 转换：\n"
            f"  doc2md '{file.filename}' | curl -X POST -F 'file=@-;filename=input.md' "
            f"-F 'domain={domain}' http://localhost:8765/ingest\n"
            f"或使用便利端点：\n"
            f"  POST /ingest/convert （需要系统安装 doc2md）",
        )

    content = await file.read()
    md_text = content.decode("utf-8", errors="replace")

    return _process_text(md_text, file.filename or "unknown.md", domain)


# ── 便利入口：/ingest/convert（调外部 doc2md） ────────

@app.post("/ingest/convert", response_model=IngestResponse)
async def ingest_convert(
    file: UploadFile = File(...),
    domain: str = Form("GENERAL"),
):
    """上传任意文档 → 调用外部 doc2md 转换 → 分块 → 嵌入 → 存入 Chroma。

    需要系统安装 doc2md（`which doc2md`）。
    如果转换失败，返回错误信息而不影响现有知识。
    """
    if _vs is None or _rag is None or _checker is None:
        raise HTTPException(500, "服务未就绪")

    # 如果是文本格式，直接走 /ingest 路径
    if _is_text_file(file.filename):
        content = await file.read()
        md_text = content.decode("utf-8", errors="replace")
        result = _process_text(md_text, file.filename or "unknown.md", domain)
        result.convert_used = False
        return result

    # 检查 doc2md 是否可用
    try:
        subprocess.run(["which", "doc2md"], capture_output=True, check=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        raise HTTPException(
            501,
            "系统未安装 doc2md。请先安装 doc2md 技能，或手动将文档转换为 Markdown "
            "后使用 POST /ingest。",
        )

    # 通过 doc2md 转换
    content = await file.read()
    suffix = Path(file.filename or "unknown").suffix.lower()

    with tempfile.NamedTemporaryFile(delete=False, suffix=suffix) as tmp:
        tmp.write(content)
        tmp_path = tmp.name

    try:
        result = subprocess.run(
            ["doc2md", tmp_path],
            capture_output=True, text=True, timeout=120,
        )
        if result.returncode != 0:
            raise HTTPException(422,
                                f"doc2md 转换失败 (exit={result.returncode}): "
                                f"{result.stderr[:500]}")
        md_text = result.stdout.strip()
        if not md_text:
            raise HTTPException(422, "doc2md 输出为空")

        ingest_result = _process_text(
            md_text, file.filename or "converted.md", domain
        )
        ingest_result.convert_used = True
        return ingest_result
    finally:
        Path(tmp_path).unlink(missing_ok=True)


# ── 共享处理逻辑 ────────────────────────────────────────

def _process_text(md_text: str, source_name: str, domain: str) -> IngestResponse:
    """将 MD 文本分块 → 嵌入 → 存储。"""
    chunks = chunk_document(md_text, domain=domain)
    if not chunks:
        return IngestResponse(
            status="warning",
            chunks=0,
            domain=domain,
            events=[],
        )

    texts = [c["content"] for c in chunks]
    metadatas = [
        {
            "source": source_name,
            "domain": domain,
            "heading": c.get("heading") or "",
            "heading_chain": " > ".join(c.get("heading_chain", [])),
            "chunk_index": c["chunk_index"],
            "quality_score": c["quality_score"],
            "quality_issues": ",".join(c.get("quality_issues", [])),
            "chars": c["chars"],
        }
        for c in chunks
    ]

    _vs.add(texts, metadatas)
    events = _checker.after_ingest(domain, len(chunks))

    return IngestResponse(
        status="ok",
        chunks=len(chunks),
        domain=domain,
        events=events,
    )


# ── 查询/反馈/统计/centroids ───────────────────────────

@app.get("/query", response_model=QueryResponse)
async def search_query(q: str, top_k: int = 5, domain: Optional[str] = None):
    """语义搜索知识库。"""
    if _rag is None:
        raise HTTPException(500, "服务未就绪")
    result = _rag.query(q, top_k=top_k, domain=domain)
    if _checker:
        _checker.after_query(domain)
    return result


@app.post("/feedback")
async def submit_feedback(req: FeedbackRequest):
    """提交检索结果评分。"""
    if _rag is None or _checker is None:
        raise HTTPException(500, "服务未就绪")
    result = _rag.feedback(req.query_id, req.doc_id, req.score, req.user_id)
    events = _checker.after_feedback()
    return {**result, "events": events}


@app.get("/domains")
async def list_domains():
    """列出所有已知知识域。"""
    if _vs is None:
        raise HTTPException(500, "服务未就绪")
    domains = _vs.list_domains()
    return {
        "domains": [
            {"name": d, "count": _vs.count_by_domain(d)}
            for d in domains
        ]
    }


@app.get("/stats", response_model=StatsResponse)
async def stats():
    """系统统计。"""
    if _vs is None or _rag is None:
        raise HTTPException(500, "服务未就绪")
    domains = _vs.list_domains()
    centroid_path = _cfg.data_dir / "centroids.json"
    centroids_count = 0
    if centroid_path.exists():
        import json
        with open(centroid_path) as f:
            centroids_count = len(json.load(f))

    return StatsResponse(
        total_chunks=_vs.count(),
        domains=[
            {"name": d, "count": _vs.count_by_domain(d)}
            for d in domains
        ],
        total_feedback=_rag.count_feedback(),
        centroids_count=centroids_count,
    )


@app.post("/centroids")
async def rebuild_centroids():
    """手动触发 centroid 重建。"""
    if _rag is None:
        raise HTTPException(500, "服务未就绪")
    result = _rag.rebuild_centroids()
    return {"status": "ok", "domains": result}


# ── 分類端點 ──────────────────────────────────────────────

class ClassifyResponse(BaseModel):
    domain: str
    level: str
    type: str
    method: str
    confidence: float
    text_preview: str


@app.get("/classify", response_model=ClassifyResponse)
async def classify_text(text: str = Query(..., description="待分類的文本")):
    """對文本進行領域分類。"""
    from .classify import classify as _classify
    result = _classify(text[:500])
    return ClassifyResponse(
        domain=result.get("domain", "GENERAL"),
        level=result.get("level", "L2"),
        type=result.get("type", "DECLARATIVE"),
        method=result.get("method", "regex_fallback"),
        confidence=result.get("confidence", 0.0),
        text_preview=text[:80],
    )


# ── 启动入口 ────────────────────────────────────────────

def main():
    import uvicorn
    uvicorn.run(
        "server.app.main:app",
        host=_cfg.host,
        port=_cfg.port,
        reload=False,
    )


if __name__ == "__main__":
    main()
